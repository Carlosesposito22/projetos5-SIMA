# SIMA — variáveis de ambiente (copiar para .env e preencher)

# --- Django ---
DJANGO_SECRET_KEY=troque-isso-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Postgres (ver docker-compose.yml) ---
DATABASE_URL=postgres://sima:sima@localhost:5432/sima
POSTGRES_DB=sima
POSTGRES_USER=sima
POSTGRES_PASSWORD=sima

# --- APIs meteorológicas ---
OPENWEATHER_API_KEY=
TOMORROW_API_KEY=

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
