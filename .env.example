# SIMA — variáveis de ambiente (copiar para .env e preencher)

# --- Django ---
DJANGO_SECRET_KEY=troque-isso-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Postgres (ver docker-compose.yml) ---
# Use 'localhost' quando rodar o Django direto na máquina (fora do Docker);
# no docker-compose, a variável DATABASE_URL é sobrescrita pra apontar pra
# 'postgres' (hostname interno da rede do compose).
DATABASE_URL=postgres://sima:sima@localhost:5432/sima
POSTGRES_DB=sima
POSTGRES_USER=sima
POSTGRES_PASSWORD=sima

# --- Frontend (Vite) ---
# URL que o navegador (não o container) usa pra falar com a API.
VITE_API_URL=http://localhost:8000
# URL do dashboard analítico Streamlit (aba "Analytics" no painel).
# Em produção: URL pública do serviço sima-analytics no Render.
VITE_ANALYTICS_URL=http://localhost:8501

# --- APIs meteorológicas ---
OPENWEATHER_API_KEY=
TOMORROW_API_KEY=

# --- WhatsApp (Meta Cloud API) ---
# Deixe comentado enquanto usar Twilio
# SIMA_WA_PROVIDER=meta
# META_WA_TOKEN=
# META_WA_PHONE_ID=
# META_WA_VERIFY_TOKEN=
# META_WA_TEMPLATE_NAME=alerta_alagamento
# META_WA_APP_SECRET=

SIMA_APP_URL=http://localhost:5173

# --- WhatsApp (Twilio Sandbox) ---
SIMA_WA_PROVIDER=twilio

# Account SID — começa com AC (em twilio.com/console)
TWILIO_ACCOUNT_SID=

# Auth Token — em twilio.com/console
TWILIO_AUTH_TOKEN=

# Número do Sandbox Twilio (não mude esse valor)
TWILIO_WA_FROM=whatsapp:+14155238886

# Content Template SID (opcional — ver apps/alertas/whatsapp.py)
TWILIO_WA_TEMPLATE_SID=
